<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.examp.springmvc.user.infrastructure.mapper.UserQueryMapper">

    <resultMap id="userResultMap" type="com.examp.springmvc.user.infrastructure.persistence.UserDbEntity">
        <id property="id" column="ID"/>
        <result property="username" column="USERNAME"/>
        <result property="fullName" column="FULL_NAME"/>
        <result property="email" column="EMAIL"/>
        <result property="phone" column="PHONE"/>
        <result property="status" column="STATUS"/>
        <result property="password" column="PASSWORD"/>
        <result property="role" column="ROLE"/>
        <result property="createdAt" column="CREATED_AT"/>
        <result property="updatedAt" column="UPDATED_AT"/>
    </resultMap>

    <sql id="userColumns">
        ID,
        USERNAME,
        FULL_NAME,
        EMAIL,
        PHONE,
        STATUS,
        PASSWORD,
        ROLE,
        CREATED_AT,
        UPDATED_AT
    </sql>

    <select id="findAll" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM APP_USERS
        ORDER BY ID DESC
    </select>

    <select id="findPaged" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM APP_USERS
        ORDER BY ID DESC
        OFFSET #{offset} ROWS FETCH NEXT #{limit} ROWS ONLY
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM APP_USERS
    </select>

    <select id="findById" parameterType="long" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM APP_USERS
        WHERE ID = #{id, jdbcType=NUMERIC}
    </select>

    <select id="findByUsername" parameterType="string" resultMap="userResultMap">
        SELECT <include refid="userColumns"/>
        FROM APP_USERS
        WHERE USERNAME = #{username, jdbcType=VARCHAR}
    </select>

</mapper>
